KV_APP_NAME=Kontroll
KV_BRAND_ORG_NAME=Minfiskerikontroll
KV_PRODUCTION_MODE=1
SESSION_SECRET=sett-en-lang-og-unik-hemmelig-verdi
KV_DATA_ENCRYPTION_KEY=sett-en-lang-og-unik-krypteringsnoekkel
KV_ALLOWED_HOSTS=www.dittdomene.no,dittdomene.onrender.com
SERVER_URL=https://www.dittdomene.no
KV_SESSION_HTTPS_ONLY=1
KV_SESSION_MAX_AGE_SECONDS=43200
KV_SESSION_IDLE_MINUTES=30
KV_SESSION_ABSOLUTE_MINUTES=720
KV_DB_PATH=./kv_kontroll.db
KV_UPLOAD_DIR=./uploads
KV_GENERATED_DIR=./generated
KV_LOG_LEVEL=INFO
KV_MAX_REQUEST_MB=30
KV_MAX_UPLOAD_MB=30
KV_OCR_MAX_IMAGE_MB=12
OPENAI_API_KEY=
KV_OPENAI_API_KEY=
KV_OPENAI_VISION_MODEL=gpt-4.1
KV_OPENAI_VISION_MAX_IMAGES=4
KV_OPENAI_VISION_MAX_IMAGE_MB=16
KV_OPENAI_VISION_MAX_SIDE=4200
KV_OPENAI_VISION_MIN_LONG_SIDE=2600
KV_OPENAI_VISION_JPEG_QUALITY=96
KV_OPENAI_VISION_MAX_OUTPUT_TOKENS=1200
KV_MAP_BUNDLE_MAX_LAYERS=14
KV_MIN_PASSWORD_LENGTH=14
KV_LOGIN_RATE_LIMIT_ATTEMPTS=8
KV_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
KV_LIVE_SOURCES=1
KV_PORTAL_MAPSERVER=https://gis.fiskeridir.no/server/rest/services/Yggdrasil/Fiskerireguleringer/MapServer
KV_BOOTSTRAP_ADMIN_EMAIL=navn@domene.no
KV_BOOTSTRAP_ADMIN_NAME=Fullt Navn
KV_BOOTSTRAP_ADMIN_PASSWORD=VelgEtSterktPassord123!Ekstra
KV_BOOTSTRAP_ADMIN_PREFIX=LBHN

# Render/persistent lagring
KV_STORAGE_ROOT=/var/data/fiskerikontroll

# E-postutsending av dokumentpakke. Må settes for at "Send anmeldelse med vedlegg" skal virke.
KV_SMTP_HOST=smtp.dittdomene.no
KV_SMTP_PORT=587
KV_SMTP_FROM=noreply@dittdomene.no
KV_SMTP_USERNAME=
KV_SMTP_PASSWORD=
KV_SMTP_USE_TLS=0
KV_SMTP_USE_STARTTLS=1

# SMS / OTP-innlogging (Twilio)
# Sett KV_SMS_PROVIDER=twilio og fyll inn Twilio-verdiene for produksjon.
# I dev-modus logges OTP-koden til stdout (ingen SMS sendes).
KV_SMS_PROVIDER=
KV_TWILIO_ACCOUNT_SID=
KV_TWILIO_AUTH_TOKEN=
KV_TWILIO_FROM_NUMBER=+47XXXXXXXX
